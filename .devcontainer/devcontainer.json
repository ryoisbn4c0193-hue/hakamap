{
  "name": "Hakamap й–Ӣзҷәз’°еўғ",
  "image": "mcr.microsoft.com/devcontainers/java:3-21-bookworm",

  "runArgs": ["--security-opt=seccomp=unconfined"],

  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "none",
      "installMaven": true,
      "installGradle": false
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts",
      "nodeGypDependencies": true,
      "pnpmVersion": "latest"
    }
  },

  "containerEnv": {
    "LANG": "C.UTF-8",
    "LC_ALL": "C.UTF-8",
    "TZ": "Asia/Tokyo"
  },

  "forwardPorts": [5173, 8080],
  "portsAttributes": {
    "5173": {
      "label": "Vite й–ӢзҷәгӮөгғјгғҗгғј",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Spring Boot й–ӢзҷәгӮөгғјгғҗгғј",
      "onAutoForward": "notify"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "openai.chatgpt",
        "vscjava.vscode-java-pack",
        "shengchen.vscode-checkstyle",
        "vmware.vscode-spring-boot",
        "vscjava.vscode-spring-initializr",
        "vscjava.vscode-maven",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "editorconfig.editorconfig",
        "vitest.explorer",
        "ms-playwright.playwright",
        "yoavbls.pretty-ts-errors",
        "redhat.vscode-xml"
      ],
      "settings": {
        "files.encoding": "utf8",
        "files.eol": "\n",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "[javascript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[javascriptreact]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "java.configuration.updateBuildConfiguration": "automatic",
        "java.compile.nullAnalysis.mode": "automatic",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "postCreateCommand": ".devcontainer/postCreate.sh",
  "remoteUser": "vscode",
  "shutdownAction": "stopContainer"
}
